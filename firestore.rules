rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminUser() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'password';
    }
    
    function isPlayer(uid) {
      return request.auth.uid == uid;
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // System collection (gameState & eventConfig) - allow all authenticated writes for API routes
    match /system/{document} {
      allow read: if isAuthenticated();     
      allow write: if isAuthenticated();
    }

    // Players collection
    match /players/{playerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isPlayer(playerId);
      allow update: if (isAuthenticated() && isPlayer(playerId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentSubmission', 'submittedAt', 'lastSeen'])) 
        || isAuthenticated();
      allow delete: if isAdminUser();
    }
    
    // Submissions collection
    match /submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.playerId == request.auth.uid;
      allow update, delete: if isAuthenticated();
    }
    
    // Pairs collection
    match /pairs/{slotId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Sequence pairs - C9 sequence match game
    match /sequencePairs/{pairId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Lemon assignments - for GameLemons
    match /lemonAssignments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Market trades - for GameLemons
    match /marketTrades/{tradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.buyerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
      allow delete: if false;
    }
    
    // Admin audit log
    match /adminAuditLog/{logId} {
      allow read, write: if isAuthenticated();
    }
    
    // Rate limiting
    match /rateLimits/{limitId} {
      allow read, write: if isAuthenticated();
    }
    
    // Idempotency keys
    match /idempotencyKeys/{keyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
