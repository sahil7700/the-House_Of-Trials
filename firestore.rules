rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isPlayer(uid) {
      return request.auth.uid == uid;
    }
    
    function isAdminUser() {
      // Admin users are stored in the admins collection with their UID as document ID
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Admins collection - only readable by authenticated, writable only by existing admins
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // System collection - game state and event config
    match /system/{docId} {
      // gameState - players can read, only admins can write
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
      
      // eventConfig - players can read (for game rules), only admins can write
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // Players collection
    match /players/{playerId} {
      // Players can read ALL player data (needed for leaderboards, pairings, etc.)
      // This is a game show so privacy is limited
      allow read: if isAuthenticated();
      
      // Players can only write to their own document
      allow create: if isAuthenticated() && isPlayer(playerId);
      allow update: if isAuthenticated() && isPlayer(playerId) && 
        // Prevent players from modifying their own status/points through direct write
        // Only allow updating currentSubmission and submittedAt
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['currentSubmission', 'submittedAt', 'lastSeen']);
      allow delete: if false; // Never delete players
    }
    
    // Submissions collection - immutable once written
    match /submissions/{submissionId} {
      // Anyone authenticated can read submissions (for admin dashboard)
      allow read: if isAuthenticated();
      
      // Submissions can only be created, never updated or deleted
      // The submissionId format is: slotNumber_uid
      allow create: if isAuthenticated() && 
        // The player can only create submissions with their own uid
        request.resource.data.playerId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // Pairs collection - for C9 sequence match game
    match /pairs/{slotId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // Lemon assignments - for GameLemons
    match /lemonAssignments/{docId} {
      allow read: if isAuthenticated();
      // Only admins can write assignments
      allow write: if isAdminUser();
    }
    
    // Market trades - for GameLemons
    match /marketTrades/{tradeId} {
      allow read: if isAuthenticated();
      // Players can only create trades for themselves as seller
      // and update trades where they are the buyer (accept/decline)
      allow create: if isAuthenticated() && 
        request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && 
        resource.data.buyerId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
      allow delete: if false;
    }
    
    // Admin audit log - only admins can read/write
    match /adminAuditLog/{logId} {
      allow read, write: if isAdminUser();
    }
    
    // Rate limiting - prevent spam submissions
    match /rateLimits/{limitId} {
      allow read, write: if isAuthenticated();
    }
    
    // Submission idempotency keys
    match /idempotencyKeys/{keyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
