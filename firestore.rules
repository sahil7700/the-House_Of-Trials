rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the Admin (logged in via email instead of anonymous)
    function isAdminUser() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'password';
    }
    
    // Legacy mapping just in case
    function isPlayer(uid) {
      return request.auth.uid == uid;
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // System collection (gameState & eventConfig)
    match /system/{document} {
      allow read: if isAuthenticated();     
      allow write: if isAdminUser();   
    }

    // Players collection
    match /players/{playerId} {
      // Players can read ALL player data 
      allow read: if isAuthenticated();
      
      // Players can only write to their own document upon registry
      allow create: if isAuthenticated() && isPlayer(playerId);
      
      // Players can update their specific submission fields, Admins can do anything
      allow update: if (isAuthenticated() && isPlayer(playerId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentSubmission', 'submittedAt', 'lastSeen'])) 
        || isAdminUser();
        
      // Only Admin can delete players during Event Reset
      allow delete: if isAdminUser();
    }
    
    // Submissions collection
    match /submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.playerId == request.auth.uid;
      allow update, delete: if isAdminUser();
    }
    
    // Pairs collection - for C9 sequence match game (legacy)
    match /pairs/{slotId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // Sequence pairs - C9 sequence match game (individual pair docs)
    match /sequencePairs/{pairId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // Lemon assignments - for GameLemons
    match /lemonAssignments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }
    
    // Market trades - for GameLemons
    match /marketTrades/{tradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.buyerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
      allow delete: if false;
    }
    
    // Admin audit log
    match /adminAuditLog/{logId} {
      allow read, write: if isAdminUser();
    }
    
    // Rate limiting
    match /rateLimits/{limitId} {
      allow read, write: if isAuthenticated();
    }
    
    // Submission idempotency keys
    match /idempotencyKeys/{keyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
